    {
      "parameters": {
        "jsCode": "const prenom = $json.body.prenom || 'toi';\nconst email = $json.body.email || '';\n\n// Nettoyage numéro WhatsApp\nlet whatsapp = $json.body.whatsapp || '';\nwhatsapp = whatsapp.replace(/\\s/g, '').replace('+', '');\nconst whatsapp_clean = whatsapp + '@c.us';\n\n// Prix officiels\nconst offre1 = 5900;\nconst offre2 = 11900;\nconst offre3 = 17900;\n\n// Réduction 50%\nconst reduction = 50;\nconst offre1Reduite = Math.round(offre1 * (1 - reduction / 100));\nconst offre2Reduite = Math.round(offre2 * (1 - reduction / 100));\nconst offre3Reduite = Math.round(offre3 * (1 - reduction / 100));\n\nreturn [{\n  prenom,\n  email,\n  whatsapp,\n  whatsapp_clean,\n  offre1,\n  offre2,\n  offre3,\n  offre1Reduite,\n  offre2Reduite,\n  offre3Reduite,\n  reduction,\n  codePromo: 'ANCESTRAL50'\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-352, 208],
      "id": "178625e3-ae67-4a98-887b-7826b83c5c87",
