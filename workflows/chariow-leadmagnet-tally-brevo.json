    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst fields = body?.data?.fields || [];\n\nlet prenom = '';\nlet email = '';\n\nfor (const field of fields) {\n  const label = (field.label || '').toLowerCase().trim();\n  const value = field.value || '';\n\n  if (label.includes('prenom') || label.includes('prénom') || label.includes('nom') || label.includes('name')) {\n    prenom = value.trim();\n  }\n  if (label.includes('mail') || label.includes('email') || field.type === 'INPUT_EMAIL') {\n    email = value.trim().toLowerCase();\n  }\n}\n\nif (!prenom && fields[0]) prenom = fields[0].value || 'Ami';\nif (!email && fields[1]) email = fields[1].value || '';\n\nif (!email) {\n  throw new Error('Email non trouvé dans la soumission Tally');\n}\n\nconst prenomFormate = prenom\n  ? prenom.charAt(0).toUpperCase() + prenom.slice(1).toLowerCase()\n  : 'Ami';\n\nreturn [{\n  json: {\n    prenom: prenomFormate,\n    email: email,\n    source: 'tally-lead-magnet',\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
